---
import Layout from '../layouts/Layout.astro';
import { staticSettings, waLink, telLink, homeTeaser } from '../lib/content.js';
---

<Layout title="Home" active="Home">
  <!-- HERO -->
  <section style="position:relative;padding:clamp(32px,6vw,40px) clamp(20px,5vw,64px) clamp(60px,8vw,90px);background-image:linear-gradient(180deg,rgba(24,19,16,0.88),rgba(24,19,16,0.72) 45%,rgba(24,19,16,0.96)),url('/images/pizza-pepperoni-whole.png');background-size:cover;background-position:center;">
    <div style="display:inline-flex;align-items:center;gap:10px;background:var(--card);border:1px solid var(--border);border-radius:100px;padding:8px 18px 8px 10px;margin-bottom:28px;white-space:nowrap;">
      <span style="width:10px;height:10px;border-radius:50%;background:var(--lime);display:inline-block;animation:neonPulse 1.8s ease-in-out infinite;flex-shrink:0;"></span>
      <span class="font-display" style="font-size:clamp(11px,1.6vw,13px);letter-spacing:1.2px;color:var(--lime);">OPEN NOW · TILL 11:30PM</span>
    </div>

    <h1 class="font-display" style="font-size:clamp(48px,9vw,124px);letter-spacing:0.5px;text-transform:uppercase;max-width:1100px;text-wrap:pretty;">
      <span style="color:var(--text);display:block;line-height:1.25;">Fries hot.</span>
      <span style="color:var(--orange);display:block;line-height:1.25;">Pizza hot.</span>
      <span style="color:var(--red);-webkit-text-stroke:2px var(--text);display:block;line-height:1.25;">Line moves fast.</span>
    </h1>

    <p style="font-size:clamp(17px,2vw,22px);color:var(--text-dim);max-width:520px;margin-top:28px;line-height:1.5;">
      Pantang West's late-night fry and pizza spot. Message us on WhatsApp or give us a call and we start cooking the second you order.
    </p>

    <div style="display:flex;flex-wrap:wrap;gap:16px;margin-top:36px;">
      <a href={waLink("Hi Rabeck's, I'd like to order")} style="background:var(--whatsapp);color:var(--whatsapp-text);text-decoration:none;font-weight:800;font-size:clamp(16px,1.6vw,19px);padding:18px 32px;border-radius:100px;display:inline-flex;align-items:center;gap:10px;">
        Order on WhatsApp <span style="font-size:20px;">↗</span>
      </a>
      <a href={telLink()} style="border:2px solid var(--text);color:var(--text);text-decoration:none;font-weight:700;font-size:clamp(16px,1.6vw,19px);padding:16px 30px;border-radius:100px;display:inline-flex;align-items:center;gap:10px;">
        Call to Order <span style="font-size:18px;">☎</span>
      </a>
    </div>

    <div style="display:flex;flex-wrap:wrap;gap:clamp(16px,3vw,40px);margin-top:56px;padding-top:28px;border-top:1px solid var(--border);color:var(--text-muted);font-size:14px;font-weight:600;letter-spacing:0.5px;">
      <span>★ {staticSettings.rating} RATED</span>
      <span>{staticSettings.addressArea.toUpperCase()}</span>
      <span>WHATSAPP OR PHONE ORDERS</span>
      <a href="/menu" style="color:var(--lime);text-decoration:none;">See the Menu →</a>
    </div>
  </section>

  <!-- FEATURE STRIP -->
  <section style="background:var(--bg-alt);padding:clamp(48px,7vw,80px) clamp(20px,5vw,64px);display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:32px;">
    <div>
      <div class="font-display" style="font-size:34px;color:var(--orange);">01</div>
      <h3 style="font-size:20px;margin-top:10px;color:var(--text);">Hot &amp; fast</h3>
      <p style="color:var(--text-muted);font-size:15px;margin-top:8px;line-height:1.5;">Fried to order, boxed while it's still crackling. No sitting under a heat lamp here.</p>
    </div>
    <div>
      <div class="font-display" style="font-size:34px;color:var(--lime);">02</div>
      <h3 style="font-size:20px;margin-top:10px;color:var(--text);">WhatsApp or call</h3>
      <p style="color:var(--text-muted);font-size:15px;margin-top:8px;line-height:1.5;">No app, no account, no forms. Message us or call — either way, get your food. That's the whole system.</p>
    </div>
    <div>
      <div class="font-display" style="font-size:34px;color:var(--red);">03</div>
      <h3 style="font-size:20px;margin-top:10px;color:var(--text);">Open late</h3>
      <p style="color:var(--text-muted);font-size:15px;margin-top:8px;line-height:1.5;">Till 11:30pm, every night. When the craving hits at 10, we're the one still cooking.</p>
    </div>
  </section>

  <!-- MENU TEASER -->
  <section style="padding:clamp(56px,8vw,96px) clamp(20px,5vw,64px);">
    <div style="display:flex;flex-wrap:wrap;justify-content:space-between;align-items:baseline;gap:16px;margin-bottom:36px;">
      <h2 class="font-display" style="font-size:clamp(32px,5vw,52px);text-transform:uppercase;color:var(--text);">A taste of the menu</h2>
      <a href="/menu" style="color:var(--lime);text-decoration:none;font-weight:700;font-size:15px;">Full menu →</a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:20px;">
      {homeTeaser.map(item => (
        <div style="background:var(--card);border-radius:14px;overflow:hidden;">
          <img src={item.image} alt={item.name} style="width:100%;aspect-ratio:4/3;object-fit:cover;display:block;" />
          <div style="padding:16px;">
            <div style="font-weight:700;color:var(--text);">{item.name}</div>
            <div style="color:var(--text-muted);font-size:13px;margin-top:4px;">{item.price}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ABOUT TEASER -->
  <section style="background:var(--bg-alt);padding:clamp(56px,8vw,96px) clamp(20px,5vw,64px);display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:40px;align-items:center;">
    <img src="/images/kitchen-action.png" alt="Rabeck's kitchen at work" style="width:100%;aspect-ratio:5/4;object-fit:cover;border-radius:16px;display:block;" />
    <div>
      <h2 class="font-display" style="font-size:clamp(30px,4vw,44px);text-transform:uppercase;color:var(--text);line-height:1.05;">Pantang West's own</h2>
      <p style="color:var(--text-muted);font-size:17px;margin-top:18px;line-height:1.6;max-width:480px;">We started as a fry stand for the neighborhood. Now we're the spot people message at 10pm because nowhere else is still cooking. Same corner. Same recipe. Longer hours.</p>
      <a href="/about" style="color:var(--lime);text-decoration:none;font-weight:700;font-size:15px;display:inline-block;margin-top:20px;">Our story →</a>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section style="padding:clamp(64px,9vw,110px) clamp(20px,5vw,64px);text-align:center;background:linear-gradient(180deg,var(--bg),#1F1712);">
    <h2 class="font-display" style="font-size:clamp(38px,6vw,68px);text-transform:uppercase;color:var(--text);">Hungry right now?</h2>
    <p style="color:var(--text-muted);font-size:17px;margin-top:12px;">Send us a message or give us a call. We'll take it from there.</p>
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:16px;margin-top:32px;">
      <a href={waLink("Hi Rabeck's, I'd like to order")} style="background:var(--whatsapp);color:var(--whatsapp-text);text-decoration:none;font-weight:800;font-size:20px;padding:20px 40px;border-radius:100px;display:inline-flex;align-items:center;gap:10px;">
        Order on WhatsApp <span style="font-size:22px;">↗</span>
      </a>
      <a href={telLink()} style="border:2px solid var(--text);color:var(--text);text-decoration:none;font-weight:800;font-size:20px;padding:20px 40px;border-radius:100px;display:inline-flex;align-items:center;gap:10px;">
        Call to Order <span style="font-size:20px;">☎</span>
      </a>
    </div>
    <div style="margin-top:16px;color:var(--text-muted);font-size:14px;">{staticSettings.phoneDisplay} · {staticSettings.addressArea}</div>
  </section>
</Layout>
