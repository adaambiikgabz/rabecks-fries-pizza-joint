---
import Layout from '../layouts/Layout.astro';
import { waLink } from '../lib/content.js';
---

<Layout title="Page Not Found">
  <section style="padding:clamp(64px,10vw,120px) clamp(20px,5vw,64px);text-align:center;">
    <span style="font-family:monospace;font-size:13px;color:var(--orange);letter-spacing:1px;">404</span>
    <h1 class="font-display" style="font-size:clamp(38px,6vw,68px);text-transform:uppercase;color:var(--text);margin-top:12px;">Not on the menu.</h1>
    <p style="color:var(--text-muted);font-size:17px;margin-top:12px;max-width:480px;margin-left:auto;margin-right:auto;">That page doesn't exist. Head back home or order what does.</p>
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:16px;margin-top:32px;">
      <a href="/" style="background:var(--whatsapp);color:var(--whatsapp-text);text-decoration:none;font-weight:800;font-size:18px;padding:18px 32px;border-radius:100px;">
        Back to Home
      </a>
      <a href={waLink("Hi Rabeck's, I'd like to order")} style="border:2px solid var(--text);color:var(--text);text-decoration:none;font-weight:700;font-size:18px;padding:16px 30px;border-radius:100px;">
        Order on WhatsApp
      </a>
    </div>
  </section>
</Layout>
