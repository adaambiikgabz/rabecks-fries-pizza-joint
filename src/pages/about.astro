---
import Layout from '../layouts/Layout.astro';
import { staticSettings, waLink, telLink } from '../lib/content.js';
---

<Layout title="About" active="About">
  <!-- HERO -->
  <section style="padding:clamp(24px,4vw,32px) clamp(20px,5vw,64px) clamp(48px,7vw,72px);">
    <h1 class="font-display" style="font-size:clamp(44px,8vw,92px);text-transform:uppercase;line-height:0.98;color:var(--text);max-width:900px;">Our Story</h1>
  </section>

  <!-- STORY -->
  <section style="padding:0 clamp(20px,5vw,64px) clamp(56px,8vw,90px);display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:48px;align-items:start;">
    <img src="/images/kitchen-action.png" alt="Rabeck's kitchen, fries in the fryer" style="width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:16px;display:block;" />
    <div>
      <p style="font-size:18px;line-height:1.7;color:var(--text-dim);">
        Rabeck's started as a small fry stand in Pantang West, serving the block one bag at a time. People kept showing up, even after the other spots had closed. So we stayed open later. Then later than that.
      </p>
      <p style="font-size:18px;line-height:1.7;color:var(--text-dim);margin-top:20px;">
        Now we're a proper fries and pizza joint, but the corner is the same and the standard hasn't moved. Everything is cooked fresh when you order it, not before. That's the whole reason we're open till 11:30pm: because the craving doesn't check the time, and neither do we.
      </p>
      <p style="font-size:18px;line-height:1.7;color:var(--text-dim);margin-top:20px;">
        {staticSettings.rating} stars didn't come from a marketing push. It came from showing up, night after night, and getting the food right.
      </p>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="background:var(--bg-alt);padding:clamp(48px,7vw,72px) clamp(20px,5vw,64px);display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;text-align:center;">
    <div>
      <div class="font-display" style="font-size:clamp(38px,5vw,56px);color:var(--lime);">{staticSettings.rating}★</div>
      <div style="color:var(--text-muted);font-size:14px;margin-top:6px;letter-spacing:0.5px;">CUSTOMER RATING</div>
    </div>
    <div>
      <div class="font-display" style="font-size:clamp(38px,5vw,56px);color:var(--orange);">11:30PM</div>
      <div style="color:var(--text-muted);font-size:14px;margin-top:6px;letter-spacing:0.5px;">OPEN TILL, DAILY</div>
    </div>
    <div>
      <div class="font-display" style="font-size:clamp(38px,5vw,56px);color:var(--red);">WHATSAPP OR CALL</div>
      <div style="color:var(--text-muted);font-size:14px;margin-top:6px;letter-spacing:0.5px;">HOW YOU ORDER</div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:clamp(64px,9vw,100px) clamp(20px,5vw,64px);text-align:center;">
    <h2 class="font-display" style="font-size:clamp(34px,5vw,56px);text-transform:uppercase;color:var(--text);">Come taste why they rate us {staticSettings.rating}.</h2>
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:16px;margin-top:28px;">
      <a href={waLink("Hi Rabeck's, I'd like to order")} style="background:var(--whatsapp);color:var(--whatsapp-text);text-decoration:none;font-weight:800;font-size:19px;padding:18px 36px;border-radius:100px;display:inline-flex;align-items:center;gap:10px;">
        Order on WhatsApp <span style="font-size:20px;">↗</span>
      </a>
      <a href={telLink()} style="border:2px solid var(--text);color:var(--text);text-decoration:none;font-weight:800;font-size:19px;padding:18px 36px;border-radius:100px;display:inline-flex;align-items:center;gap:10px;">
        Call to Order <span style="font-size:18px;">☎</span>
      </a>
    </div>
  </section>
</Layout>
